{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "setup": "git clone --depth 1 https://github.com/Yanch-ers/obsidian_vault.git content/obsidian && rm -rf content/obsidian/.git",
    "dev": "astro dev",
    "build": "astro build",
    "build:cf": "rm -rf content/obsidian && echo \"https://${GH_TOKEN}:x-oauth-basic@github.com\" > ~/.git-credentials && git config --global credential.helper store && git clone --depth 1 https://github.com/Yanch-ers/obsidian_vault.git content/obsidian && rm -rf content/obsidian/.git && npm run build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.3.2",
    "unified": "^11.0.5",
    "wrangler": "^4.107.0"
  }
}
