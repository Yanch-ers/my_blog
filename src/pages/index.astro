---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import LargePostCard from '../components/LargePostCard.astro';
import HeroSection from '../components/HeroSection.astro';
import Sidebar from '../components/Sidebar.astro';
import { getAllPosts } from '../lib/content';

const allPosts = await getAllPosts();

const POSTS_PER_PAGE = 12;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const pagePosts = allPosts.slice(0, POSTS_PER_PAGE);
const featuredPost = pagePosts[0];
const remainingPosts = pagePosts.slice(1);

const techCount = allPosts.filter((p) => p.collection === 'tech').length;
const essaysCount = allPosts.filter((p) => p.collection === 'essays').length;
---

<BaseLayout title="首页">
  <Header />

  <main class="mx-auto flex max-w-[1600px] flex-1 flex-col px-6 py-10">
    <HeroSection techCount={techCount} essaysCount={essaysCount} />

    <div class="flex flex-col gap-8 xl:flex-row xl:items-start">
      <div id="posts" class="flex flex-col gap-6 flex-1">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-serif text-2xl font-bold text-gray-900">精选文章</h2>
            <p class="mt-1 text-sm text-gray-500">最新发布的技术文章和随笔</p>
          </div>
          {totalPages > 1 && (
            <a
              href="/page/2"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 transition-colors hover:text-blue-700"
            >
              查看更多
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          )}
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {featuredPost && (
            <div class="animate-fade-in lg:col-span-2">
              <LargePostCard post={featuredPost} />
            </div>
          )}
          {remainingPosts.map((post, index) => (
            <div class={`animate-fade-in animate-delay-${Math.min(index + 1, 3)}`}>
              <PostCard post={post} />
            </div>
          ))}
        </div>

        {allPosts.length === 0 && (
          <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gray-100 mb-6">
              <span class="text-4xl">📝</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">暂无文章</h3>
            <p class="text-sm text-gray-500">敬请期待更多内容</p>
          </div>
        )}

        {totalPages > 1 && (
          <nav class="mt-8 flex items-center justify-center gap-3">
            <span class="text-sm text-gray-400">第 1 / {totalPages} 页</span>
            <a
              href="/page/2"
              class="inline-flex items-center gap-2 rounded-xl border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-600 transition-all hover:border-blue-300 hover:text-blue-600 hover:shadow-sm"
            >
              下一页
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          </nav>
        )}
      </div>

      <Sidebar />
    </div>
  </main>

  <Footer />
</BaseLayout>
