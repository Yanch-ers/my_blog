---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="页面未找到">
  <Header />

  <main class="mx-auto flex min-h-[60vh] max-w-md items-center justify-center px-6 py-12">
    <div class="text-center animate-fade-in">
      <!-- Illustration -->
      <div class="mb-8 inline-flex h-40 w-40 items-center justify-center rounded-full bg-gradient-to-br from-teal-50 to-emerald-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] opacity-60">
          <circle cx="12" cy="12" r="10" />
          <path d="m15 9-6 6" />
          <path d="m9 9 6 6" />
        </svg>
      </div>

      <!-- Content -->
      <h1 class="font-serif text-2xl font-bold tracking-tight text-[var(--color-text)] mb-2">
        页面未找到
      </h1>
      <p class="text-sm text-[var(--color-text-muted)] mb-8">
        你访问的页面可能已被移动或删除
      </p>

      <!-- CTA Button -->
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-teal-500 to-emerald-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-teal-500/20 transition-all hover:shadow-xl hover:shadow-teal-500/30 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z" /><polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        返回首页
      </a>
    </div>
  </main>

  <Footer maxWidth="max-w-md" />
</BaseLayout>
