---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import TagList from '../../../components/TagList.astro';
import VideoPlayer from '../../../components/VideoPlayer';
import { getCollection, render } from 'astro:content';
import { getDate, getTags, getSummary, formatDate, readingTime } from '../../../lib/content';

export const prerender = true;

export async function getStaticPaths() {
  const [techPosts, essayPosts] = await Promise.all([
    getCollection('tech'),
    getCollection('essays'),
  ]);
  return [
    ...techPosts.map((post) => ({
      params: { collection: 'tech', slug: post.id },
      props: { post },
    })),
    ...essayPosts.map((post) => ({
      params: { collection: 'essays', slug: post.id },
      props: { post },
    })),
  ];
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const date = getDate(post);
const tags = getTags(post);
const summary = getSummary(post);
const formattedDate = formatDate(date);
const bodyText = post.body ?? '';
const rt = readingTime(bodyText);
const charCount = bodyText.replace(/\s/g, '').length;

// Generate TOC from h2 and h3 headings
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={post.data.title} description={summary}>
  <Header />

  <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-12">
    <!-- Reading Progress Bar -->
    <div id="progress-bar" class="progress-bar" style="width: 0%" />

    <!-- Article Header -->
    <header class="mb-10 animate-fade-in">
      <h1 class="text-3xl font-bold leading-tight tracking-tight text-[var(--color-text)] sm:text-4xl">
        {post.data.title}
      </h1>

      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-text-muted)]">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-[var(--color-border)]">·</span>
        <span>{rt} 分钟阅读</span>
        <span class="text-[var(--color-border)]">·</span>
        <span>{charCount} 字</span>
        {post.collection === 'essays' && (
          <>
            <span class="text-[var(--color-border)]">·</span>
            <span class="rounded-full bg-[var(--color-bg-secondary)] px-2 py-0.5 text-xs">随笔</span>
          </>
        )}
      </div>

      {tags.length > 0 && (
        <div class="mt-4">
          <TagList tags={tags} size="sm" />
        </div>
      )}

      {summary && (
        <div class="mt-6 rounded-lg border-l-4 border-[var(--color-accent)] bg-[var(--color-bg-secondary)] px-5 py-4">
          <p class="text-base leading-relaxed text-[var(--color-text-secondary)]">
            {summary}
          </p>
        </div>
      )}
    </header>

    <!-- Table of Contents (inline, collapsible) -->
    {toc.length > 0 && (
      <details class="toc-container mb-10 animate-fade-in animate-delay-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
        <summary class="flex cursor-pointer items-center justify-between px-5 py-3 text-sm font-semibold text-[var(--color-text)] select-none hover:text-[var(--color-accent)] transition-colors">
          <span>目录</span>
          <svg class="toc-chevron h-4 w-4 text-[var(--color-text-muted)] transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <nav class="px-5 pb-4 pt-1">
          <ul class="flex flex-col gap-1">
            {toc.map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'block rounded px-2 py-1 text-sm transition-colors hover:bg-[var(--color-bg)] hover:text-[var(--color-accent)]',
                    heading.depth === 3
                      ? 'pl-6 text-[var(--color-text-muted)]'
                      : 'font-medium text-[var(--color-text-secondary)]',
                  ]}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </details>
    )}

    <!-- Article Content -->
    <article class="prose animate-fade-in animate-delay-1">
      <Content />
    </article>

    <!-- Video Player (conditional) -->
    {(post.data as any).video && (
      <div class="mt-10 animate-fade-in">
        <VideoPlayer client:load src={(post.data as any).video} />
      </div>
    )}

    <!-- Article Footer -->
    <div class="mt-16 border-t border-[var(--color-border)] pt-8">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-accent)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7" /><path d="M19 12H5" />
        </svg>
        返回首页
      </a>
    </div>
  </main>

  <Footer />

  <!-- Reading Progress Script -->
  <script is:inline>
    (function () {
      const bar = document.getElementById('progress-bar');
      if (!bar) return;
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = progress + '%';
      });
    })();
  </script>
</BaseLayout>
