---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RightNavPanel from '../../components/RightNavPanel.astro';
import GraphVisualization from '../../components/GraphVisualization';
import { getAllTags, getAllSubCategories, getTagDimensions, getTagColor, buildGraphData } from '../../lib/content';

const tagMap = await getAllTags();
const subCategories = await getAllSubCategories();
const tagDimensions = await getTagDimensions();
const graphData = await buildGraphData();

const tags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签" noVideoBackground={true}>
  <Header />
  <RightNavPanel />

  <main class="mx-auto w-full max-w-5xl px-6 py-12">
    <div class="glass-panel rounded-2xl p-8 md:p-10">
    <header class="mb-10 animate-fade-in">
      <p class="mb-2 text-sm font-medium text-[var(--color-accent)]">标签</p>
      <h1 class="font-serif text-3xl font-bold tracking-tight text-[var(--color-text)]">
        标签云
      </h1>
      <div class="mt-3 h-px w-16 bg-gradient-to-r from-[var(--color-accent)] to-transparent" />
      <p class="mt-3 text-[var(--color-text-secondary)]">
        共 {tags.length} 个标签，{subCategories.length} 个分类
      </p>
    </header>

    <section class="mb-10 animate-fade-in animate-delay-1">
      <h2 class="mb-5 flex items-center gap-3 text-base font-bold text-[var(--color-text)]">
          <span class="inline-block h-5 w-1.5 rounded-full bg-gradient-to-b from-[var(--color-accent)] to-emerald-400" />
          分类导航
        </h2>
      <div class="flex flex-wrap gap-2">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-teal-500 to-emerald-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-teal-500/20 transition-all hover:shadow-xl hover:-translate-y-0.5"
        >
          全部文章
        </a>
        {subCategories.map((cat) => {
          const color = getTagColor(cat.id);
          return (
            <a
              key={cat.id}
              href={`/tags/${cat.id}`}
              class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-card)] px-4 py-2 text-sm text-[var(--color-text)] transition-all hover:border-[var(--color-accent)] hover:shadow-md hover:shadow-emerald-500/10 hover:-translate-y-0.5"
            >
              {cat.icon}
              {cat.name}
              <span class="rounded-full bg-[var(--color-bg-secondary)] px-2 py-0.5 text-xs text-[var(--color-text-muted)]">
                {cat.count}
              </span>
            </a>
          );
        })}
      </div>
    </section>

    {tagDimensions.length > 0 && (
      <section class="mb-10 animate-fade-in animate-delay-1">
        <h2 class="mb-5 flex items-center gap-3 text-base font-bold text-[var(--color-text)]">
          <span class="inline-block h-5 w-1.5 rounded-full bg-gradient-to-b from-[var(--color-accent)] to-emerald-400" />
          标签维度
        </h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {tagDimensions.map((dim) => (
            <div key={dim.id} class="glass-card rounded-2xl p-4">
              <p class="mb-3 text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">{dim.name}</p>
              <div class="flex flex-wrap gap-2">
                {dim.values.map((value) => {
                  const color = getTagColor(value.id);
                  return (
                    <a
                      key={value.id}
                      href={`/tags/${value.id}`}
                      class="inline-flex items-center gap-1 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-card)] px-3 py-1.5 text-xs text-[var(--color-text)] transition-all hover:border-[var(--color-accent)] hover:shadow-sm hover:shadow-emerald-500/10 hover:-translate-y-0.5"
                    >
                      {value.name}
                      <span class="text-[var(--color-text-muted)]">{value.count}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="animate-fade-in animate-delay-2">
      <h2 class="mb-5 flex items-center gap-3 text-base font-bold text-[var(--color-text)]">
        <span class="inline-block h-5 w-1.5 rounded-full bg-gradient-to-b from-[var(--color-accent)] to-emerald-400" />
        知识图谱
      </h2>
      <p class="mb-4 text-xs text-[var(--color-text-muted)]">基于文章双向链接自动生成，节点大小表示连接强度，颜色区分分类</p>
      <GraphVisualization nodes={graphData.nodes} edges={graphData.edges} client:load />
    </section>

    {tags.length === 0 && (
      <p class="py-12 text-center text-[var(--color-text-muted)]">暂无标签</p>
    )}
    </div>
  </main>

  <div class="mx-auto w-full max-w-5xl px-6 py-8">
    <Footer />
  </div>
</BaseLayout>
