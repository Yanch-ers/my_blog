---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllTags } from '../../lib/content';

const tagMap = await getAllTags();
const tags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签">
  <Header />

  <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-12">
    <h1 class="mb-10 text-3xl font-bold tracking-tight text-[var(--color-text)] animate-fade-in">
      标签
    </h1>

    <div class="flex flex-wrap gap-3 animate-fade-in animate-delay-1">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="group inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] px-4 py-2 text-sm transition-all hover:border-[var(--color-accent)]/30 hover:shadow-sm"
        >
          <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
            {tag}
          </span>
          <span class="rounded-full bg-[var(--color-bg-secondary)] px-2 py-0.5 text-xs text-[var(--color-text-muted)]">
            {count}
          </span>
        </a>
      ))}
    </div>

    {tags.length === 0 && (
      <p class="py-12 text-center text-[var(--color-text-muted)]">暂无标签</p>
    )}
  </main>

  <Footer />
</BaseLayout>
