---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import RightNavPanel from '../../components/RightNavPanel.astro';
import { getAllPosts } from '../../lib/content';

export const prerender = true;

export async function getStaticPaths() {
  const allPosts = await getAllPosts();

  const POSTS_PER_PAGE = 12;
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => {
    const startIndex = i * POSTS_PER_PAGE;
    return {
      params: { page: String(i + 1) },
      props: {
        posts: allPosts.slice(startIndex, startIndex + POSTS_PER_PAGE),
        currentPage: i + 1,
        totalPages,
      },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`第 ${currentPage} 页`}>
  <Header />
  <RightNavPanel />

  <main class="mx-auto max-w-5xl px-6 py-8">
    <div class="glass-panel rounded-3xl p-6 md:p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif text-xl font-bold text-[var(--color-text)]">精选文章</h2>
        <span class="text-xs text-[var(--color-text-muted)]">第 {currentPage} / {totalPages} 页</span>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post: any, index: number) => (
          <div class={`w-full animate-fade-in animate-delay-${Math.min(index + 1, 3)}`}>
            <PostCard post={post} />
          </div>
        ))}
      </div>

      <nav class="mt-8 flex items-center justify-center gap-3">
        {currentPage > 1 && (
          <a
            href={`/page/${currentPage - 1}`}
            class="inline-flex items-center gap-2 rounded-xl glass-button px-5 py-2.5 text-sm font-medium text-[var(--color-text-secondary)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6" />
            </svg>
            上一页
          </a>
        )}
        <span class="text-xs text-[var(--color-text-muted)]">
          {currentPage} / {totalPages}
        </span>
        {currentPage < totalPages && (
          <a
            href={`/page/${currentPage + 1}`}
            class="inline-flex items-center gap-2 rounded-xl glass-button px-5 py-2.5 text-sm font-medium text-[var(--color-text-secondary)]"
          >
            下一页
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        )}
      </nav>
    </div>
  </main>

  <Footer />
</BaseLayout>
