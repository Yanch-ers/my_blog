---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RightNavPanel from '../components/RightNavPanel.astro';
import SearchBar from '../components/SearchBar';
---

<BaseLayout title="搜索">
  <Header />
  <RightNavPanel />

  <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-12">
    <div class="glass-panel rounded-3xl p-6 md:p-8">
      <h1 class="mb-6 font-serif text-2xl font-bold tracking-tight text-[var(--color-text)] animate-fade-in">
        搜索
      </h1>

      <div class="animate-fade-in animate-delay-1">
        <SearchBar client:load />
      </div>
    </div>
  </main>

  <div class="mx-auto w-full max-w-3xl px-6 py-8">
    <Footer />
  </div>
</BaseLayout>
