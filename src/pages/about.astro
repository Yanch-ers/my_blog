---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RightNavPanel from '../components/RightNavPanel.astro';
import ContributionGraph from '../components/ContributionGraph';
import { getAllPosts, getDate } from '../lib/content';

const allPosts = await getAllPosts();
const techCount = allPosts.filter((p) => p.collection === 'tech').length;
const essaysCount = allPosts.filter((p) => p.collection === 'essays').length;
const articleDates = allPosts.map((p) => getDate(p).toISOString());
---

<BaseLayout title="关于">
  <Header />
  <RightNavPanel />

  <main class="mx-auto max-w-2xl px-6 py-10">
    <!-- Profile section -->
    <section class="animate-fade-in text-center mb-8">
      <img src="https://my-blog-1369148642.cos.ap-guangzhou.myqcloud.com/head_photo.jpg" alt="avatar" class="inline-block h-20 w-20 rounded-full object-cover shadow-lg shadow-teal-500/10 mb-4" />
      <h1 class="font-serif text-2xl font-bold tracking-tight text-[var(--color-text)] mb-2">
        关于 YANCHE BLOG
      </h1>
      <p class="text-sm text-[var(--color-text-secondary)]">
        云原生 / Linux / 数据库 / AI运维
      </p>
    </section>

    <!-- Bio -->
    <section class="animate-fade-in animate-delay-1 mb-6">
      <div class="glass-card rounded-2xl p-6">
        <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">
          这里主要分享云原生、Linux 环境、工具效率和界面设计相关内容。我偏好清晰、克制、可复用的表达方式。
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="grid grid-cols-2 gap-3 mb-6 animate-fade-in animate-delay-1">
      <div class="glass-card rounded-2xl p-5 text-center">
        <p class="text-2xl font-bold text-[var(--color-accent)]">{techCount + essaysCount}</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">总文章数</p>
      </div>
      <div class="glass-card rounded-2xl p-5 text-center">
        <p class="text-2xl font-bold text-[var(--color-accent)]">{techCount}</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">技术文章</p>
      </div>
    </section>

    <!-- Contribution Graph -->
    <section class="glass-card rounded-2xl p-6 mb-6 animate-fade-in animate-delay-2">
      <ContributionGraph dates={articleDates} client:load />
    </section>

    <!-- Tech stack -->
    <section class="glass-card rounded-2xl p-6 mb-6 animate-fade-in animate-delay-2">
      <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">技术栈</h3>
      <div class="flex flex-wrap gap-2">
        {['Linux', 'Kubernetes', 'Docker', 'MySQL', 'Redis', 'Kafka', 'Python', 'Astro'].map((tech) => (
          <span class="rounded-full bg-[var(--color-accent-light)] px-3 py-1 text-xs font-medium text-[var(--color-accent)]">{tech}</span>
        ))}
      </div>
    </section>

    <!-- Blog info -->
    <section class="glass-card rounded-2xl p-6 mb-6 animate-fade-in animate-delay-2">
      <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">关于这个博客</h3>
      <div class="grid gap-3 text-sm text-[var(--color-text-secondary)]">
        <div class="flex items-center justify-between">
          <span class="text-[var(--color-text-muted)]">框架</span>
          <span>Astro 7</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[var(--color-text-muted)]">样式</span>
          <span>Tailwind CSS 4</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[var(--color-text-muted)]">部署</span>
          <span>腾讯云 EdgeOne</span>
        </div>
      </div>
    </section>

    <!-- Links -->
    <section class="flex flex-col gap-2 animate-fade-in animate-delay-2">
      <a
        href="/rss.xml"
        class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-teal-500 to-emerald-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-teal-500/20 transition-all hover:shadow-xl hover:shadow-teal-500/30"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 12a8 8 0 0 1 8-8 8.5 8.5 0 0 1 7.5 4.75 8 8 0 0 1-4.5 11.25" />
          <path d="M12 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
        </svg>
        RSS 订阅
      </a>
      <a
        href="/"
        class="flex w-full items-center justify-center gap-2 rounded-xl glass-button px-4 py-3 text-sm font-medium text-[var(--color-text-secondary)] transition-all hover:text-[var(--color-accent)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z" /><polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        返回首页
      </a>
    </section>
  </main>

  <Footer />
</BaseLayout>
