---
import type { AnyPost } from '../lib/content';
import { getDate, getTags, getSummary, formatDate, getSubCategoryName, getCategoryColor, readingTime } from '../lib/content';

interface Props {
  post: AnyPost;
}

const { post } = Astro.props;
const date = getDate(post);
const tags = getTags(post);
const summary = getSummary(post);
const dateStr = formatDate(date);
const subCategoryName = getSubCategoryName(post);
const isEssay = post.collection === 'essays';
const accentColor = isEssay ? '#f43f5e' : getCategoryColor(subCategoryName);
const bodyText = post.body ?? '';
const rt = readingTime(bodyText);
---

<article class="group relative rounded-xl post-card overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5">
  <a
    href={`/posts/${post.collection}/${post.id}`}
    class="block p-4"
  >
    <!-- Top row: category + date -->
    <div class="flex items-center justify-between gap-2 mb-2">
      <div class="flex items-center gap-2">
        {subCategoryName && !isEssay && (
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold" style={`background-color: ${accentColor}15; color: ${accentColor}`}>
            {subCategoryName}
          </span>
        )}
        {isEssay && (
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold" style="background-color: #f43f5e15; color: #f43f5e">
            随笔
          </span>
        )}
      </div>
      <span class="text-[10px] font-medium text-[var(--color-text-muted)] whitespace-nowrap flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2" /><line x1="16" x2="16" y1="2" y2="6" /><line x1="8" x2="8" y1="2" y2="6" /><line x1="3" x2="21" y1="10" y2="10" />
        </svg>
        {dateStr}
      </span>
    </div>

    <!-- Title -->
    <h2 class="font-serif text-sm font-extrabold leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)] line-clamp-2 mb-2">
      {post.data.title}
    </h2>

    <!-- Bottom: tags + read time -->
    <div class="flex items-center justify-between">
      <div class="flex flex-wrap gap-1">
        {tags.slice(0, 3).map((tag) => (
          <span
            key={tag}
            class="inline-flex items-center rounded-full bg-[var(--color-bg-secondary)] px-1.5 py-0.5 text-[9px] font-medium text-[var(--color-text-muted)]"
          >
            {tag}
          </span>
        ))}
      </div>
      <span class="text-[10px] font-medium text-[var(--color-text-muted)]">{rt} min</span>
    </div>
  </a>
</article>
