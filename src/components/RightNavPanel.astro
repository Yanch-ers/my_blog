---
import { getAllSubCategories, getAllTags } from '../lib/content';

const subCategories = await getAllSubCategories();
const tags = await getAllTags();

const sortedTags = Array.from(tags.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// Main navigation items
const mainNavItems = [
  { href: '/', label: '首页', icon: 'home' },
  { href: '/tags/', label: '标签', icon: 'tag' },
  { href: '/search', label: '搜索', icon: 'search' },
  { href: '/about', label: '关于', icon: 'user' },
];

// Category nav items (from subCategories)
const categoryNavItems = subCategories.map((cat) => ({
  href: `/tags/${cat.id}`,
  label: cat.name,
  count: cat.count,
}));
---

<!-- Backdrop -->
<div
  id="right-nav-backdrop"
  class="fixed inset-0 bg-black/20 backdrop-blur-sm transition-opacity duration-300 right-nav-backdrop-closed"
  style="z-index: 55;"
></div>

<!-- Panel -->
<div
  id="right-nav-panel"
  data-open="false"
  class="fixed z-[60] flex flex-col right-nav-panel-closed"
>
  <!-- Drag handle for mobile -->
  <div class="flex justify-center pt-2 pb-1 md:hidden">
    <div class="h-1 w-10 rounded-full bg-gray-400/40"></div>
  </div>

  <!-- Panel content -->
  <div class="glass-panel flex flex-col overflow-hidden h-full rounded-t-none md:rounded-2xl">
    <!-- Panel header -->
    <div class="flex items-center justify-between border-b border-[var(--color-border)] px-5 py-4">
      <div class="flex items-center gap-2.5">
        <img src="https://my-blog-1369148642.cos.ap-guangzhou.myqcloud.com/head_photo.jpg" alt="logo" class="h-8 w-8 rounded-full object-cover" />
        <div>
          <h3 class="font-bold text-sm text-[var(--color-text)]">YancheBlog</h3>
          <p class="text-[10px] text-[var(--color-text-muted)]">云原生运维技术笔记</p>
        </div>
      </div>
      <button
        id="right-nav-close-btn"
        class="flex h-8 w-8 items-center justify-center rounded-full text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-text)]"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto scrollbar-thin px-4 py-3">
      <!-- Main navigation -->
      <nav class="mb-4 flex flex-col gap-0.5">
        {mainNavItems.map((item) => {
          const icons: Record<string, string> = {
            home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z" /><polyline points="9 22 9 12 15 12 15 22" />',
            tag: '<path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z" /><path d="M7 7h.01" />',
            search: '<circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />',
            user: '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />',
          };
          return (
            <a
              href={item.href}
              class="flex items-center justify-between rounded-xl px-3.5 py-2.5 text-sm text-[var(--color-text-secondary)] transition-all hover:bg-[var(--color-accent-light)] hover:text-[var(--color-accent)] group"
            >
              <span class="flex items-center gap-3">
                <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[var(--color-accent-light)] text-[var(--color-accent)]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" innerHTML={icons[item.icon] || icons.home} />
                </span>
                {item.label}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-muted)] opacity-0 group-hover:opacity-100 transition-opacity">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          );
        })}
      </nav>

      <!-- Divider -->
      <div class="my-3 h-px bg-[var(--color-border)]" />

      <!-- Categories -->
      <nav class="mb-4 flex flex-col gap-0.5">
        {categoryNavItems.map((item) => (
          <a
            href={item.href}
            class="flex items-center justify-between rounded-xl px-3.5 py-2.5 text-sm text-[var(--color-text-secondary)] transition-all hover:bg-[var(--color-accent-light)] hover:text-[var(--color-accent)] group"
          >
            <span class="flex items-center gap-3">
              <span class="h-2 w-2 rounded-full bg-[var(--color-accent)]" />
              {item.label}
            </span>
            <span class="flex items-center gap-2">
              <span class="text-[10px] text-[var(--color-text-muted)]">{item.count}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-muted)] opacity-0 group-hover:opacity-100 transition-opacity">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </span>
          </a>
        ))}
      </nav>

      <!-- Tags -->
      {sortedTags.length > 0 && (
        <>
          <div class="my-3 h-px bg-[var(--color-border)]" />
          <div class="mb-4">
            <h4 class="mb-2.5 px-3.5 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">热门标签</h4>
            <div class="flex flex-wrap gap-1.5 px-3.5">
              {sortedTags.map(([tag, count]) => (
                <a
                  key={tag}
                  href={`/tags/${tag}`}
                  class="inline-flex items-center gap-1 rounded-full bg-[var(--color-bg-secondary)] px-2.5 py-1 text-[11px] text-[var(--color-text-secondary)] transition-all hover:bg-[var(--color-accent-light)] hover:text-[var(--color-accent)]"
                >
                  {tag}
                  <span class="text-[9px] opacity-50">{count}</span>
                </a>
              ))}
            </div>
          </div>
        </>
      )}
    </div>

    <!-- RSS footer -->
    <div class="border-t border-[var(--color-border)] px-4 py-3">
      <a
        href="/rss.xml"
        class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-teal-500 to-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-teal-500/20 transition-all hover:shadow-xl hover:shadow-teal-500/30"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 12a8 8 0 0 1 8-8 8.5 8.5 0 0 1 7.5 4.75 8 8 0 0 1-4.5 11.25" />
          <path d="M12 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
        </svg>
        RSS 订阅
      </a>
    </div>
  </div>
</div>

<script>
  function toggleRightNav() {
    const panel = document.getElementById('right-nav-panel');
    const backdrop = document.getElementById('right-nav-backdrop');
    if (!panel || !backdrop) return;

    const isOpen = panel.dataset.open === 'true';
    if (isOpen) {
      panel.classList.remove('right-nav-panel-open');
      panel.classList.add('right-nav-panel-closed');
      backdrop.classList.remove('right-nav-backdrop-open');
      backdrop.classList.add('right-nav-backdrop-closed');
      panel.dataset.open = 'false';
    } else {
      panel.classList.remove('right-nav-panel-closed');
      panel.classList.add('right-nav-panel-open');
      backdrop.classList.remove('right-nav-backdrop-closed');
      backdrop.classList.add('right-nav-backdrop-open');
      panel.dataset.open = 'true';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('right-nav-toggle');
    const toggleBtnMobile = document.getElementById('right-nav-toggle-mobile');
    const closeBtn = document.getElementById('right-nav-close-btn');
    const backdrop = document.getElementById('right-nav-backdrop');
    if (toggleBtn) toggleBtn.addEventListener('click', toggleRightNav);
    if (toggleBtnMobile) toggleBtnMobile.addEventListener('click', toggleRightNav);
    if (closeBtn) closeBtn.addEventListener('click', toggleRightNav);
    if (backdrop) backdrop.addEventListener('click', toggleRightNav);
  });
</script>
