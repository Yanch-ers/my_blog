---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noVideoBackground?: boolean;
}

const { title, description = '一个简约高级的个人博客', noVideoBackground = false } = Astro.props;
const siteName = 'Yanche Blog';
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Dark mode init (avoid flash) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class:list={['min-h-screen flex flex-col antialiased', { 'tags-bg': noVideoBackground }]}>
    {!noVideoBackground && (
      <>
        <!-- Video forest background -->
        <video 
          autoplay 
          loop 
          muted 
          playsinline
          preload="auto"
          class="fixed inset-0 w-full h-full object-cover"
          style="z-index: 0;"
          aria-hidden="true"
          onerror="this.style.display='none'"
        >
          <source src="https://my-blog-1369148642.cos.ap-guangzhou.myqcloud.com/forest-bg.mp4" type="video/mp4" />
        </video>
        
        <!-- Fallback background (shown when video fails to load on mobile) -->
        <div 
          class="fixed inset-0"
          style="z-index: -1; background: linear-gradient(135deg, #0a1a0a 0%, #0d2818 30%, #0a1a0a 60%, #071510 100%);"
          aria-hidden="true"
        ></div>
        
        <!-- Dark overlay for readability -->
        <div 
          class="fixed inset-0 pointer-events-none"
          style="z-index: 1; background: rgba(0, 0, 0, 0.1);"
          aria-hidden="true"
        ></div>
      </>
    )}
    
    <!-- Main content -->
    <div class="flex flex-col flex-1" style="position: relative; z-index: 10;">
      <slot />
    </div>

    <!-- Dark mode toggle script -->
    <script is:inline>
      window.toggleTheme = function () {
        const html = document.documentElement;
        const isDark = html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      };
    </script>

    <!-- Video background fallback -->
    <script is:inline>
      (function () {
        var video = document.querySelector('video');
        if (!video) return;
        
        // Detect mobile / low-power mode
        var isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
        
        // Try to play, hide video if fails
        var playPromise = video.play();
        if (playPromise !== undefined) {
          playPromise.catch(function () {
            video.style.display = 'none';
          });
        }
        
        // Also handle source error
        var source = video.querySelector('source');
        if (source) {
          source.addEventListener('error', function () {
            video.style.display = 'none';
          });
        }
        
        // On mobile, reduce video quality expectations - just show gradient if video is slow
        if (isMobile) {
          setTimeout(function () {
            if (video.readyState < 2) {
              video.style.display = 'none';
            }
          }, 3000);
        }
      })();
    </script>

    <!-- Scroll reveal observer -->
    <script is:inline>
      (function () {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
        });
      })();
    </script>
  </body>
</html>
