{
  "version": 3,
  "conf": {
    "redirects": []
  },
  "routes": [
    {
      "src": "^/([^.]+[^/.])$",
      "dest": "/$1/",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/_server-islands/([^/]+?)/?$"
    },
    {
      "src": "^/_image/?$"
    },
    {
      "src": "^/api/search/?$"
    },
    {
      "src": "^/api/upload/?$"
    },
    {
      "src": "^/404/?$"
    },
    {
      "src": "^/(.*)$"
    }
  ]
}